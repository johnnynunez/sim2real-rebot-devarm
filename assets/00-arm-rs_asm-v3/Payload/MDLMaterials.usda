def Scope "Materials"
{
    def Material "ABS_Hard_Leather"
    {
        token outputs:mdl:displacement.connect = </Materials/ABS_Hard_Leather/Shader.outputs:out>
        token outputs:mdl:surface.connect = </Materials/ABS_Hard_Leather/Shader.outputs:out>
        token outputs:mdl:volume.connect = </Materials/ABS_Hard_Leather/Shader.outputs:out>

        def Shader "Shader"
        {
            uniform token info:implementationSource = "sourceAsset"
            uniform asset info:mdl:sourceAsset = @https://omniverse-content-production.s3.us-west-2.amazonaws.com/Materials/2023_1/vMaterials_2/Leather/ABS_Hard_Leather.mdl@
            uniform token info:mdl:sourceAsset:subIdentifier = "ABS_Hard_Leather"
            token outputs:out (
                renderType = "material"
            )
        }
    }

